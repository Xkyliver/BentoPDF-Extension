  "manifest_version": 2,
  "name": "Bento PDF",
  "version": "1.0",
  "description": "An armory of tools for BentoPDF",
  "icons": {
    "48": "icon.png" 
  },
  "permissions": [
    "tabs",
    "activeTab"
  ],
